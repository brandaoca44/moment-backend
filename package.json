    "@types/jest": "^29.5.3",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/sharp": "^0.31.1",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
