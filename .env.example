# App
NODE_ENV=development
PORT=3333
APP_NAME=Moment
APP_URL=http://localhost:3000
API_URL=http://localhost:3333

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/moment?schema=public"

# Auth
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Upload
MAX_FILE_SIZE_MB=5
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Rate limit
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Redis
REDIS_URL=redis://localhost:6379

# Storage
STORAGE_DRIVER=local
STORAGE_BASE_URL=http://localhost:3333/uploads

# Moderation
OPENAI_API_KEY=your_openai_api_key_here

# R2 Storage
R2_ACCOUNT_ID=seu_account_id
R2_ACCESS_KEY_ID=seu_access_key_id
R2_SECRET_ACCESS_KEY=seu_secret_access_key
R2_BUCKET_NAME=moment-uploads
R2_PUBLIC_URL=https://sua_url_publica.r2.dev